# Local development only. Production values should be set with `npx wrangler secret put`.

# Discord bot token used to send channel messages.
DISCORD_TOKEN=your_discord_bot_token_here

# Optional defaults. These can also be saved from the admin dashboard.
GUILD_ID=your_guild_id_here
DISCORD_CHANNEL_ID=your_notification_channel_id_here
TIKTOK_USERNAME=clawzpokeshipz

# Admin login. If ADMIN_PASSWORD is not set, first login falls back to Claw / Claw69.
ADMIN_USERNAME=Claw
ADMIN_PASSWORD=create_a_strong_password_here

# Optional secondary admin login.
SECONDARY_ADMIN_USERNAME=rockets
SECONDARY_ADMIN_PASSWORD=create_a_strong_secondary_password_here

# Shared secret used by the external TikTok bot when it POSTs /update.
WORKER_UPDATE_SECRET=create_a_random_secret_password_here
